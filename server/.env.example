# Prisma CLI (migrations, db push, etc.)
DATABASE_URL="mysql://root:root@localhost:3306/illegal-construction-detection-project"

DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=root
DATABASE_NAME=illegal-construction-detection-project

# Server variables
PORT=5001
NODE_ENV=development

# Set to "true" to allow POST /api/v1/auth/register when NODE_ENV=production.
# When unset, registration is allowed only when NODE_ENV is not "production".
ALLOW_PUBLIC_REGISTRATION=

# AI inference service
AI_SERVICE_URL=http://localhost:5002/predict
AI_SERVICE_API_KEY=change-me
