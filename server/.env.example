# Prisma CLI (migrations, db push, etc.)
DATABASE_URL="mysql://root:root@localhost:3306/illegal-construction-detection-project"

DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=root
DATABASE_NAME=illegal-construction-detection-project

# Server variables
PORT=5001
NODE_ENV=development

# Frontend URL for password reset links (no trailing slash).
FRONTEND_URL=http://localhost:5173

# Gmail SMTP for welcome, password-reset, and analysis-complete emails.
# Use a Google App Password (16 chars, no spaces). Regular Gmail passwords will fail.
# On Render: add EMAIL_USER, EMAIL_PASS, and FRONTEND_URL in the API service Environment tab.
# Cloud hosts (Render): prefer port 587 if 465 times out.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Set to "true" to allow POST /api/v1/auth/register when NODE_ENV=production.
# When unset, registration is allowed only when NODE_ENV is not "production"
# (except first-account bootstrap in production when there are zero users).
ALLOW_PUBLIC_REGISTRATION=

# AI inference service
AI_SERVICE_URL=http://localhost:5002/predict
AI_SERVICE_API_KEY=change-me
# Max wait for POST /predict (ms). Default 180000 (3m). Set to 0 to disable (not recommended).
AI_SERVICE_TIMEOUT_MS=

# Optional object storage for analysis images (recommended in production).
# When unset, server falls back to local ./uploads storage.
#
# App credentials (PutObject): use an IAM user key on non-AWS hosts (e.g. Render), or an IAM role on AWS compute.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_UPLOADS_BUCKET=
# After you create a CloudFront distribution (origin = this bucket, Origin Access recommended),
# set this to the distribution domain so stored filePath URLs use the CDN (no trailing slash), e.g.:
# S3_PUBLIC_BASE_URL=https://d111111abcdef8.cloudfront.net
# If unset, the API builds direct virtual-hosted S3 URLs: https://<bucket>.s3.<region>.amazonaws.com/<key>
S3_PUBLIC_BASE_URL=
